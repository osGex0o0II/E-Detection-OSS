<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="EDetection.Desktop.Views.RunSetupView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Style="{StaticResource SettingsRailStyle}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      HorizontalScrollMode="Disabled">
            <StackPanel Spacing="12"
                        Margin="0,0,20,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="检测输入"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="选择 CSV 根目录和报告输出，运行前检查会自动完成"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock Text="数据源与报告"
                               Style="{StaticResource SectionTitleTextStyle}" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="输入目录" FontWeight="SemiBold" />
                        <Grid x:Name="InputPathGrid"
                              ColumnSpacing="8"
                              RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="0" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="InputPathTextColumn" Width="*" />
                                <ColumnDefinition x:Name="InputPathButtonColumn" Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InputDirectoryTextBox"
                                     Text="{Binding InputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanEditRunConfiguration}"
                                     PlaceholderText="选择包含 CSV 文件的目录" />
                            <Button x:Name="InputDirectoryButton"
                                    Grid.Column="1"
                                    Click="BrowseInputDirectory_Click"
                                    IsEnabled="{Binding IsIdle}"
                                    ToolTipService.ToolTip="选择输入目录">
                                <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                            </Button>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="报告目录" FontWeight="SemiBold" />
                        <Grid x:Name="OutputPathGrid"
                              ColumnSpacing="8"
                              RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="0" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="OutputPathTextColumn" Width="*" />
                                <ColumnDefinition x:Name="OutputPathButtonColumn" Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OutputDirectoryTextBox"
                                     Text="{Binding OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding CanEditRunConfiguration}"
                                     PlaceholderText="留空则写入输入目录" />
                            <Button x:Name="OutputDirectoryButton"
                                    Grid.Column="1"
                                    Click="BrowseOutputDirectory_Click"
                                    IsEnabled="{Binding IsIdle}"
                                    ToolTipService.ToolTip="选择报告目录">
                                <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                            </Button>
                        </Grid>
                    </StackPanel>

                    <ToggleSwitch Header="生成 Excel 报告"
                                  IsOn="{Binding WriteReport, Mode=TwoWay}"
                                  IsEnabled="{Binding IsIdle}" />

                    <Grid x:Name="RunCommandGrid"
                          ColumnSpacing="8"
                          RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="0" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="RunPrimaryCommandColumn" Width="*" />
                            <ColumnDefinition x:Name="RunSecondaryCommandColumn" Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="RunStartButton"
                                Command="{Binding StartCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.Name="开始检测"
                                ToolTipService.ToolTip="开始检测">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE768;" FontSize="14" />
                                <TextBlock Text="开始检测" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="RunCancelButton"
                                Grid.Column="1"
                                Command="{Binding CancelCommand}"
                                Visibility="{Binding CancelCommandVisibility}"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.Name="{Binding CancelButtonText}"
                                ToolTipService.ToolTip="{Binding CancelButtonText}">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE711;" FontSize="14" />
                                <TextBlock Text="{Binding CancelButtonText}" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="0,10,0,0">
                        <StackPanel Spacing="8">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE930;"
                                          FontSize="14"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Top"
                                          Margin="0,2,0,0" />
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{Binding RunSetupReadinessText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="WrapWholeWords" />
                                    <TextBlock Text="{Binding RunSetupReadinessDetailText}"
                                               TextWrapping="WrapWholeWords"
                                               MaxLines="2"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Grid>
                            <Expander Header="运行诊断"
                                      HorizontalAlignment="Stretch"
                                      IsExpanded="False">
                                <StackPanel Spacing="8">
                                    <Grid ColumnSpacing="10"
                                          RowSpacing="6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="输入"
                                                   Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding InputDiagnosticText}"
                                                   TextWrapping="WrapWholeWords"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Row="1"
                                                   Text="阈值"
                                                   Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Text="{Binding ConfigDiagnosticText}"
                                                   TextWrapping="WrapWholeWords"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Row="2"
                                                   Text="检测组件"
                                                   Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Text="{Binding BackendDiagnosticText}"
                                                   TextWrapping="WrapWholeWords"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Row="3"
                                                   Text="报告"
                                                   Style="{StaticResource TableHeaderTextStyle}" />
                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="1"
                                                   Text="{Binding OutputDiagnosticText}"
                                                   TextWrapping="WrapWholeWords"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Command="{Binding RefreshDiagnosticsCommand}"
                                                AutomationProperties.Name="检查状态"
                                                ToolTipService.ToolTip="检查状态">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE895;" FontSize="14" />
                                                <TextBlock Text="检查状态" />
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding CopyDiagnosticsCommand}"
                                                ToolTipService.ToolTip="复制状态详情">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                                <TextBlock Text="复制详情" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="报告历史"
                                   Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ReportHistory.StatusText}"
                                   MaxWidth="150"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>

                    <Grid x:Name="ReportHistoryFilterGrid"
                          ColumnSpacing="8"
                          RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="0" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="ReportSearchColumn" Width="*" />
                            <ColumnDefinition x:Name="ReportFilterColumn" Width="118" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ReportSearchBox"
                                 Text="{Binding ReportHistory.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="搜索报告、目录或时间" />
                        <ComboBox x:Name="ReportFilterComboBox"
                                  Grid.Column="1"
                                  SelectedIndex="{Binding ReportHistory.SelectedFilterIndex, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="全部" />
                            <ComboBoxItem Content="有异常" />
                            <ComboBoxItem Content="可打开" />
                            <ComboBoxItem Content="缺失" />
                        </ComboBox>
                    </Grid>

                    <ListView ItemsSource="{Binding ReportHistory.FilteredRecentReports}"
                              SelectedItem="{Binding ReportHistory.SelectedReport, Mode=TwoWay}"
                              MaxHeight="220"
                              SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10" Padding="0,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{Binding FileName}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Summary}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding SourceText}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding RunMetaText}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding StatusText}"
                                               MaxWidth="80"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Top" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Command="{Binding OpenSelectedReportCommand}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8A5;" FontSize="14" />
                                <TextBlock Text="打开报告" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1"
                                Command="{Binding OpenSelectedReportFolderCommand}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                                <TextBlock Text="所在目录" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Command="{Binding UseSelectedReportDirectoriesCommand}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                <TextBlock Text="复用路径" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1"
                                Command="{Binding RemoveSelectedReportCommand}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                <TextBlock Text="移除" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2"
                                Command="{Binding ClearRecentReportsCommand}"
                                ToolTipService.ToolTip="清空报告历史">
                            <FontIcon Glyph="&#xE894;" FontSize="14" />
                        </Button>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
