<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="EDetection.Desktop.Views.SettingsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d">
    <Grid x:Name="SettingsRoot" Background="Transparent" Opacity="0">
        <Grid.RenderTransform>
            <CompositeTransform x:Name="SettingsRootTransform" TranslateX="24" />
        </Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,1" Padding="24,18">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="设置" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Click="BackButton_Click" VerticalAlignment="Center" AutomationProperties.Name="返回工作台" ToolTipService.ToolTip="返回工作台">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72B;" FontSize="14" />
                        <TextBlock Text="返回" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        <Grid x:Name="SettingsBody" Grid.Row="1" Padding="24,22" ColumnSpacing="24" SizeChanged="SettingsBody_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SettingsNavColumn" Width="184" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid x:Name="SettingsNavRail" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <AutoSuggestBox x:Name="SettingsSearchBox" QueryIcon="Find" PlaceholderText="搜索设置" AutomationProperties.Name="搜索设置" TextChanged="SettingsSearchBox_TextChanged" SuggestionChosen="SettingsSearchBox_SuggestionChosen" QuerySubmitted="SettingsSearchBox_QuerySubmitted">
                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Padding="0,4">
                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding SectionTitle}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                </AutoSuggestBox>
                <ListView x:Name="SettingsCategoryList" Grid.Row="1" SelectionMode="Single" HorizontalContentAlignment="Stretch" SelectionChanged="SettingsCategoryList_SelectionChanged">
                    <ListViewItem Tag="AppearanceSection">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE790;" FontSize="15" />
                            <TextBlock Text="外观" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="DefaultsSection">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8B7;" FontSize="15" />
                            <TextBlock Text="检测" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="ThresholdsSection">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE9D2;" FontSize="15" />
                            <TextBlock Text="阈值设置" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="DetectionRulesSection">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE9D5;" FontSize="15" />
                            <TextBlock Text="检测规则" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="ReportsSection">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE9F9;" FontSize="15" />
                            <TextBlock Text="报告" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="LogsSection">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8A5;" FontSize="15" />
                            <TextBlock Text="运行记录" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="WindowSection">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE7F4;" FontSize="15" />
                            <TextBlock Text="窗口" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="LlmSection">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE950;" FontSize="15" />
                            <TextBlock Text="智能助手" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="NotificationsSection">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE7F7;" FontSize="15" />
                            <TextBlock Text="消息推送" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="ProxySection">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE968;" FontSize="15" />
                            <TextBlock Text="网络代理" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="UpdatesSection">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE895;" FontSize="15" />
                            <TextBlock Text="软件更新" />
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Tag="AdvancedSection">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE713;" FontSize="15" />
                            <TextBlock Text="高级" />
                        </StackPanel>
                    </ListViewItem>
                </ListView>
            </Grid>
            <ScrollViewer x:Name="SettingsScroll" Grid.Column="1" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled" HorizontalScrollBarVisibility="Disabled" HorizontalScrollMode="Disabled" ViewChanged="SettingsScroll_ViewChanged" SizeChanged="SettingsScroll_SizeChanged">
                <StackPanel x:Name="SettingsContentStack" MaxWidth="900" HorizontalAlignment="Stretch" Spacing="18" Padding="0,0,20,24">
                    <StackPanel x:Name="AppearanceSection" Spacing="8">
                        <TextBlock Text="外观" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <StackPanel>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="应用主题" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ComboBox Grid.Column="1" SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" AutomationProperties.Name="应用主题">
                                        <ComboBoxItem Content="跟随系统" />
                                        <ComboBoxItem Content="浅色" />
                                        <ComboBoxItem Content="深色" />
                                    </ComboBox>
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="窗口背景" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ComboBox Grid.Column="1" SelectedIndex="{Binding SelectedBackdropIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" AutomationProperties.Name="窗口背景">
                                        <ComboBoxItem Content="Mica" />
                                        <ComboBoxItem Content="Acrylic" />
                                        <ComboBoxItem Content="无" />
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel x:Name="DefaultsSection" Spacing="8">
                        <TextBlock Text="检测" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <StackPanel>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="输入目录" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Grid Grid.Column="1" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding InputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditRunConfiguration}" PlaceholderText="CSV 根目录" AutomationProperties.Name="输入目录" />
                                        <Button Grid.Column="1" Click="BrowseInputDirectory_Click" IsEnabled="{Binding CanEditRunConfiguration}" AutomationProperties.Name="选择输入目录" ToolTipService.ToolTip="选择输入目录">
                                            <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="报告目录" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Grid Grid.Column="1" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditRunConfiguration}" PlaceholderText="留空则写入输入目录" AutomationProperties.Name="报告目录" />
                                        <Button Grid.Column="1" Click="BrowseOutputDirectory_Click" IsEnabled="{Binding CanEditRunConfiguration}" AutomationProperties.Name="选择报告目录" ToolTipService.ToolTip="选择报告目录">
                                            <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="检测参数" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Grid x:Name="DetectionParametersActionGrid" Grid.Column="1" ColumnSpacing="8" RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Click="OpenThresholdSettings_Click" HorizontalAlignment="Stretch" AutomationProperties.Name="打开阈值设置">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE9D2;" FontSize="14" />
                                                <TextBlock Text="阈值设置" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Click="OpenDetectionRules_Click" HorizontalAlignment="Stretch" AutomationProperties.Name="打开检测规则">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE9D5;" FontSize="14" />
                                                <TextBlock Text="检测规则" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel x:Name="ThresholdsSection" Spacing="8">
                        <TextBlock Text="阈值设置" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <StackPanel>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="阈值配置文件" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Grid Grid.Column="1" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding ConfigPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditRunConfiguration}" PlaceholderText="默认保存在用户设置目录" AutomationProperties.Name="阈值配置文件" />
                                        <Button Grid.Column="1" Click="BrowseConfigPath_Click" IsEnabled="{Binding CanEditRunConfiguration}" AutomationProperties.Name="选择阈值配置文件" ToolTipService.ToolTip="选择阈值配置文件">
                                            <FontIcon Glyph="&#xE8A5;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </Grid>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="电压下限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <NumberBox Grid.Column="1" Value="{Binding VoltageMinThreshold, Mode=TwoWay}" Minimum="0" Maximum="1000" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="电压下限" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="电压上限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <NumberBox Grid.Column="1" Value="{Binding VoltageMaxThreshold, Mode=TwoWay}" Minimum="0" Maximum="1000" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="电压上限" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="电流上限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <NumberBox Grid.Column="1" Value="{Binding CurrentMaxThreshold, Mode=TwoWay}" Minimum="0" Maximum="100000" SmallChange="1" LargeChange="100" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="电流上限" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="功率因数下限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <NumberBox Grid.Column="1" Value="{Binding PowerFactorMinThreshold, Mode=TwoWay}" Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.05" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="功率因数下限" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="温度上限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <NumberBox Grid.Column="1" Value="{Binding TemperatureMaxThreshold, Mode=TwoWay}" Minimum="-50" Maximum="200" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="温度上限" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="冻结持续点数" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <NumberBox Grid.Column="1" Value="{Binding FreezeCountThreshold, Mode=TwoWay}" Minimum="1" Maximum="1000" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="冻结持续点数" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Expander x:Name="MoreThresholdsExpander" Header="更多阈值" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Expanding="SettingsExpander_Expanding">
                                    <StackPanel>
                                        <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" MaxWidth="320" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="电流不平衡上限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                            <NumberBox Grid.Column="1" Value="{Binding CurrentUnbalanceMaxThreshold, Mode=TwoWay}" Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.05" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="电流不平衡上限" />
                                        </Grid>
                                        <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                        <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" MaxWidth="320" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="有功功率下限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                            <NumberBox Grid.Column="1" Value="{Binding ActivePowerMinThreshold, Mode=TwoWay}" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="有功功率下限" />
                                        </Grid>
                                        <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                        <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" MaxWidth="320" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="温度下限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                            <NumberBox Grid.Column="1" Value="{Binding TemperatureMinThreshold, Mode=TwoWay}" Minimum="-50" Maximum="200" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="温度下限" />
                                        </Grid>
                                        <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                        <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" MaxWidth="320" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="电流激活下限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                            <NumberBox Grid.Column="1" Value="{Binding CurrentActiveMinThreshold, Mode=TwoWay}" Minimum="0.001" Maximum="100000" SmallChange="0.1" LargeChange="1" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="电流激活下限" />
                                        </Grid>
                                        <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                        <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" MaxWidth="320" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="冻结波动阈值" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                            <NumberBox Grid.Column="1" Value="{Binding FreezeStdThreshold, Mode=TwoWay}" Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.05" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="冻结波动阈值" />
                                        </Grid>
                                        <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                        <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" MaxWidth="320" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="相电压不平衡阈值" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                            <NumberBox Grid.Column="1" Value="{Binding VoltageImbalanceThreshold, Mode=TwoWay}" Minimum="0.001" Maximum="1" SmallChange="0.01" LargeChange="0.05" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="相电压不平衡阈值" />
                                        </Grid>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel x:Name="DetectionRulesSection" Spacing="8">
                        <TextBlock Text="检测规则" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <StackPanel>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="电流过载检测" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding CurrentOverloadEnabled, Mode=TwoWay}" AutomationProperties.Name="电流过载检测" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="电流不平衡检测" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding CurrentUnbalanceEnabled, Mode=TwoWay}" AutomationProperties.Name="电流不平衡检测" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="功率因数检测" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding PowerFactorEnabled, Mode=TwoWay}" AutomationProperties.Name="功率因数检测" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="详细异常输出" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding DetailOutputEnabled, Mode=TwoWay}" AutomationProperties.Name="详细异常输出" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel x:Name="ReportsSection" Spacing="8">
                        <TextBlock Text="报告" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <StackPanel>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="生成 Excel 报告" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding WriteReport, Mode=TwoWay}" IsEnabled="{Binding CanEditRunConfiguration}" AutomationProperties.Name="生成 Excel 报告" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="报告历史保留" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ComboBox Grid.Column="1" SelectedIndex="{Binding ReportHistory.SelectedRecentReportLimitIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" AutomationProperties.Name="报告历史保留">
                                        <ComboBoxItem Content="10 个" />
                                        <ComboBoxItem Content="20 个" />
                                        <ComboBoxItem Content="50 个" />
                                    </ComboBox>
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="清空报告历史" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Button Grid.Column="1" Command="{Binding ClearRecentReportsCommand}" HorizontalAlignment="Stretch" AutomationProperties.Name="清空报告历史">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE894;" FontSize="14" />
                                            <TextBlock Text="清空" />
