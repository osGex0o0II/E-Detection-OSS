<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="EDetection.Desktop.Views.SettingsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d">
    <Grid x:Name="SettingsRoot" Background="Transparent" Opacity="0">
        <Grid.RenderTransform>
            <CompositeTransform x:Name="SettingsRootTransform" TranslateX="24" />
        </Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,1" Padding="24,18">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="设置" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Click="BackButton_Click" VerticalAlignment="Center" ToolTipService.ToolTip="返回工作台">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72B;" FontSize="14" />
                        <TextBlock Text="返回" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        <Grid x:Name="SettingsBody" Grid.Row="1" Padding="24,22" ColumnSpacing="24" SizeChanged="SettingsBody_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SettingsNavColumn" Width="184" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ListView x:Name="SettingsCategoryList" SelectionMode="Single" HorizontalContentAlignment="Stretch" SelectionChanged="SettingsCategoryList_SelectionChanged">
                <ListViewItem Tag="AppearanceSection">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE790;" FontSize="15" />
                        <TextBlock Text="外观" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="DefaultsSection">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE8B7;" FontSize="15" />
                        <TextBlock Text="检测" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="ThresholdsSection">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE9D2;" FontSize="15" />
                        <TextBlock Text="检测阈值" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="ReportsSection">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE9F9;" FontSize="15" />
                        <TextBlock Text="报告" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="LogsSection">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE8A5;" FontSize="15" />
                        <TextBlock Text="日志" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="WindowSection">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE7F4;" FontSize="15" />
                        <TextBlock Text="窗口" />
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Tag="AdvancedSection">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE713;" FontSize="15" />
                        <TextBlock Text="高级" />
                    </StackPanel>
                </ListViewItem>
            </ListView>
            <ScrollViewer x:Name="SettingsScroll" Grid.Column="1" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled" HorizontalScrollBarVisibility="Disabled" HorizontalScrollMode="Disabled" ViewChanged="SettingsScroll_ViewChanged" SizeChanged="SettingsScroll_SizeChanged">
                <StackPanel x:Name="SettingsContentStack" MaxWidth="900" HorizontalAlignment="Stretch" Spacing="18" Padding="0,0,20,24">
                    <StackPanel x:Name="AppearanceSection" Spacing="8">
                        <TextBlock Text="外观" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <StackPanel>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="应用主题" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ComboBox Grid.Column="1" SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="跟随系统" />
                                        <ComboBoxItem Content="浅色" />
                                        <ComboBoxItem Content="深色" />
                                    </ComboBox>
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="窗口背景" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ComboBox Grid.Column="1" SelectedIndex="{Binding SelectedBackdropIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Mica" />
                                        <ComboBoxItem Content="Acrylic" />
                                        <ComboBoxItem Content="无" />
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel x:Name="DefaultsSection" Spacing="8">
                        <TextBlock Text="检测" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <StackPanel>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="输入目录" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Grid Grid.Column="1" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding InputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditRunConfiguration}" PlaceholderText="CSV 根目录" />
                                        <Button Grid.Column="1" Click="BrowseInputDirectory_Click" IsEnabled="{Binding CanEditRunConfiguration}" ToolTipService.ToolTip="选择输入目录">
                                            <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="报告目录" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Grid Grid.Column="1" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditRunConfiguration}" PlaceholderText="留空则写入输入目录" />
                                        <Button Grid.Column="1" Click="BrowseOutputDirectory_Click" IsEnabled="{Binding CanEditRunConfiguration}" ToolTipService.ToolTip="选择报告目录">
                                            <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel x:Name="ThresholdsSection" Spacing="8">
                        <TextBlock Text="检测阈值" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <StackPanel>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="电压下限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <NumberBox Grid.Column="1" Value="{Binding VoltageMinThreshold, Mode=TwoWay}" Minimum="0" Maximum="1000" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="电压下限" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="电压上限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <NumberBox Grid.Column="1" Value="{Binding VoltageMaxThreshold, Mode=TwoWay}" Minimum="0" Maximum="1000" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="电压上限" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="电流上限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <NumberBox Grid.Column="1" Value="{Binding CurrentMaxThreshold, Mode=TwoWay}" Minimum="0" Maximum="100000" SmallChange="1" LargeChange="100" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="电流上限" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="功率因数下限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <NumberBox Grid.Column="1" Value="{Binding PowerFactorMinThreshold, Mode=TwoWay}" Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.05" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="功率因数下限" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="温度上限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <NumberBox Grid.Column="1" Value="{Binding TemperatureMaxThreshold, Mode=TwoWay}" Minimum="-50" Maximum="200" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="温度上限" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="冻结持续点数" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <NumberBox Grid.Column="1" Value="{Binding FreezeCountThreshold, Mode=TwoWay}" Minimum="1" Maximum="1000" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="冻结持续点数" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Expander Header="更多阈值" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Expanding="SettingsExpander_Expanding">
                                    <StackPanel>
                                        <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" MaxWidth="320" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="电流不平衡上限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                            <NumberBox Grid.Column="1" Value="{Binding CurrentUnbalanceMaxThreshold, Mode=TwoWay}" Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.05" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="电流不平衡上限" />
                                        </Grid>
                                        <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                        <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" MaxWidth="320" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="有功功率下限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                            <NumberBox Grid.Column="1" Value="{Binding ActivePowerMinThreshold, Mode=TwoWay}" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="有功功率下限" />
                                        </Grid>
                                        <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                        <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" MaxWidth="320" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="温度下限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                            <NumberBox Grid.Column="1" Value="{Binding TemperatureMinThreshold, Mode=TwoWay}" Minimum="-50" Maximum="200" SmallChange="1" LargeChange="10" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="温度下限" />
                                        </Grid>
                                        <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                        <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" MaxWidth="320" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="电流激活下限" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                            <NumberBox Grid.Column="1" Value="{Binding CurrentActiveMinThreshold, Mode=TwoWay}" Minimum="0.001" Maximum="100000" SmallChange="0.1" LargeChange="1" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="电流激活下限" />
                                        </Grid>
                                        <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                        <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" MaxWidth="320" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="冻结波动阈值" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                            <NumberBox Grid.Column="1" Value="{Binding FreezeStdThreshold, Mode=TwoWay}" Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.05" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="冻结波动阈值" />
                                        </Grid>
                                        <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                        <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="*" MaxWidth="320" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="相电压不平衡阈值" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                            <NumberBox Grid.Column="1" Value="{Binding VoltageImbalanceThreshold, Mode=TwoWay}" Minimum="0.001" Maximum="1" SmallChange="0.01" LargeChange="0.05" SpinButtonPlacementMode="Inline" ValidationMode="InvalidInputOverwritten" AutomationProperties.Name="相电压不平衡阈值" />
                                        </Grid>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="检测规则" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <StackPanel>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="电流过载检测" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding CurrentOverloadEnabled, Mode=TwoWay}" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="电流不平衡检测" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding CurrentUnbalanceEnabled, Mode=TwoWay}" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="功率因数检测" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding PowerFactorEnabled, Mode=TwoWay}" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="详细异常输出" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding DetailOutputEnabled, Mode=TwoWay}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel x:Name="ReportsSection" Spacing="8">
                        <TextBlock Text="报告" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <StackPanel>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="生成 Excel 报告" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding WriteReport, Mode=TwoWay}" IsEnabled="{Binding CanEditRunConfiguration}" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="报告历史保留" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ComboBox Grid.Column="1" SelectedIndex="{Binding ReportHistory.SelectedRecentReportLimitIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="10 个" />
                                        <ComboBoxItem Content="20 个" />
                                        <ComboBoxItem Content="50 个" />
                                    </ComboBox>
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="清空报告历史" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Button Grid.Column="1" Command="{Binding ClearRecentReportsCommand}" HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE894;" FontSize="14" />
                                            <TextBlock Text="清空" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel x:Name="LogsSection" Spacing="8">
                        <TextBlock Text="日志" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <StackPanel>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="运行日志保留" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ComboBox Grid.Column="1" SelectedIndex="{Binding RuntimeLogs.SelectedRetentionIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="200 条" />
                                        <ComboBoxItem Content="500 条" />
                                        <ComboBoxItem Content="1000 条" />
                                        <ComboBoxItem Content="2000 条" />
                                    </ComboBox>
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="清空运行日志" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Button Grid.Column="1" Command="{Binding ClearRuntimeLogsCommand}" HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE894;" FontSize="14" />
                                            <TextBlock Text="清空" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel x:Name="WindowSection" Spacing="8">
                        <TextBlock Text="窗口" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <StackPanel>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="关闭后最小化到托盘" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding CloseToTrayOnClose, Mode=TwoWay}" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="启动时隐藏到托盘" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding StartMinimizedToTray, Mode=TwoWay}" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="桌面通知" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding EnableDesktopNotifications, Mode=TwoWay}" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="登录后自动启动" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding AutoStartOnSignIn, Mode=TwoWay}" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="全局热键" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ToggleSwitch Grid.Column="1" IsOn="{Binding EnableGlobalHotkeys, Mode=TwoWay}" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="快速操作快捷键" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <ComboBox Grid.Column="1" SelectedIndex="{Binding SelectedQuickActionsShortcutIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Ctrl+K" />
                                        <ComboBoxItem Content="Ctrl+Shift+P" />
                                        <ComboBoxItem Content="关闭" />
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel x:Name="AdvancedSection" Spacing="8">
                        <TextBlock Text="高级" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <StackPanel>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="桌面健康" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Button Grid.Column="1" Command="{Binding RefreshDesktopHealthCommand}" HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                            <TextBlock Text="刷新状态" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="检测设置文件" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Grid Grid.Column="1" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding ConfigPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditRunConfiguration}" PlaceholderText="默认检测设置" />
                                        <Button Grid.Column="1" Click="BrowseConfigPath_Click" IsEnabled="{Binding CanEditRunConfiguration}" ToolTipService.ToolTip="选择检测设置文件">
                                            <FontIcon Glyph="&#xE8A5;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="检测组件运行程序" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Grid Grid.Column="1" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding PythonExecutable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditRunConfiguration}" PlaceholderText="默认检测组件" />
                                        <Button Grid.Column="1" Click="BrowsePythonExecutable_Click" IsEnabled="{Binding CanEditRunConfiguration}" ToolTipService.ToolTip="选择检测组件运行程序">
                                            <FontIcon Glyph="&#xE756;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="设置存储" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{Binding DesktopHealth.SettingsText}" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="检测组件状态" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{Binding DesktopHealth.PythonBridgeText}" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        <Border Grid.Row="2" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="24,12">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <InfoBar IsOpen="{Binding IsSettingsFeedbackOpen, Mode=TwoWay}" Message="{Binding SettingsFeedbackText}" Severity="{Binding SettingsFeedbackSeverity}" IsIconVisible="True" IsClosable="True" MaxWidth="520" HorizontalAlignment="Left" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10">
                    <Button Command="{Binding ResetSettingsToDefaultsCommand}" MinWidth="120">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                            <TextBlock Text="重置设置" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SaveSettingsFromPageCommand}" Style="{StaticResource AccentButtonStyle}" MinWidth="128">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74E;" FontSize="14" />
                            <TextBlock Text="保存设置" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
