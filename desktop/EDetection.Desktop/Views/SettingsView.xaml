<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="EDetection.Desktop.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer x:Name="SettingsScroll"
                  VerticalScrollBarVisibility="Auto"
                  SizeChanged="SettingsScroll_SizeChanged"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="880"
                    Spacing="12"
                    Padding="0,0,4,0">
            <Grid x:Name="HeaderGrid"
                  ColumnSpacing="16"
                  RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="HeaderContentColumn" Width="*" />
                    <ColumnDefinition x:Name="HeaderSummaryColumn" Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Text="设置"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SettingsStoreStatusText}"
                               Style="{StaticResource SettingsRowSecondaryTextStyle}" />
                </StackPanel>
                <TextBlock x:Name="HeaderHealthText"
                           Grid.Column="1"
                           Text="{Binding DesktopHealth.SummaryText}"
                           MaxWidth="260"
                           VerticalAlignment="Top"
                           Style="{StaticResource SettingsRowSecondaryTextStyle}" />
            </Grid>

            <Border Style="{StaticResource SettingsSectionStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="外观"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <Grid x:Name="AppearanceGrid"
                          ColumnSpacing="16"
                          RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="AppearanceColumn0" Width="*" />
                            <ColumnDefinition x:Name="AppearanceColumn1" Width="*" />
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="ThemeComboBox"
                                  Header="主题"
                                  SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="跟随系统" />
                            <ComboBoxItem Content="浅色" />
                            <ComboBoxItem Content="深色" />
                        </ComboBox>
                        <ComboBox x:Name="BackdropComboBox"
                                  Grid.Column="1"
                                  Header="背景效果"
                                  SelectedIndex="{Binding SelectedBackdropIndex, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Mica" />
                            <ComboBoxItem Content="Acrylic" />
                            <ComboBoxItem Content="无" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSectionStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="检测默认值"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <Grid ColumnSpacing="10"
                          RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Header="输入目录"
                                 Text="{Binding InputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CanEditRunConfiguration}"
                                 PlaceholderText="CSV 根目录" />
                        <Button Grid.Column="1"
                                Click="BrowseInputDirectory_Click"
                                IsEnabled="{Binding CanEditRunConfiguration}"
                                VerticalAlignment="Bottom"
                                ToolTipService.ToolTip="选择输入目录">
                            <FontIcon Glyph="&#xE8B7;"
                                      FontSize="14" />
                        </Button>

                        <TextBox Grid.Row="1"
                                 Header="报告目录"
                                 Text="{Binding OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CanEditRunConfiguration}"
                                 PlaceholderText="留空则写入输入目录" />
                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Click="BrowseOutputDirectory_Click"
                                IsEnabled="{Binding CanEditRunConfiguration}"
                                VerticalAlignment="Bottom"
                                ToolTipService.ToolTip="选择报告目录">
                            <FontIcon Glyph="&#xE8B7;"
                                      FontSize="14" />
                        </Button>

                        <TextBox Grid.Row="2"
                                 Header="配置文件"
                                 Text="{Binding ConfigPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CanEditRunConfiguration}"
                                 PlaceholderText="config.json" />
                        <Button Grid.Row="2"
                                Grid.Column="1"
                                Click="BrowseConfigPath_Click"
                                IsEnabled="{Binding CanEditRunConfiguration}"
                                VerticalAlignment="Bottom"
                                ToolTipService.ToolTip="选择配置文件">
                            <FontIcon Glyph="&#xE8A5;"
                                      FontSize="14" />
                        </Button>

                        <TextBox Grid.Row="3"
                                 Header="Python"
                                 Text="{Binding PythonExecutable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding CanEditRunConfiguration}"
                                 PlaceholderText="python" />
                        <Button Grid.Row="3"
                                Grid.Column="1"
                                Click="BrowsePythonExecutable_Click"
                                IsEnabled="{Binding CanEditRunConfiguration}"
                                VerticalAlignment="Bottom"
                                ToolTipService.ToolTip="选择 Python 可执行文件">
                            <FontIcon Glyph="&#xE756;"
                                      FontSize="14" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSectionStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="报告与历史"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <Grid x:Name="ReportSettingsGrid"
                          ColumnSpacing="16"
                          RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="0" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="ReportSummaryColumn" Width="*" />
                            <ColumnDefinition x:Name="ReportControlColumn" Width="Auto" />
                            <ColumnDefinition x:Name="ReportButtonColumn" Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ToggleSwitch Header="生成 Excel 报告"
                                      IsOn="{Binding WriteReport, Mode=TwoWay}"
                                      IsEnabled="{Binding CanEditRunConfiguration}" />

                        <StackPanel x:Name="ReportHistorySummary"
                                    Grid.Row="1"
                                    Spacing="2"
                                    VerticalAlignment="Center">
                            <TextBlock Text="报告历史"
                                       Style="{StaticResource SettingsRowTitleTextStyle}" />
                            <TextBlock Text="{Binding ReportHistory.RecentReportLimitText}"
                                       Style="{StaticResource SettingsRowSecondaryTextStyle}" />
                        </StackPanel>
                        <ComboBox x:Name="ReportLimitComboBox"
                                  Grid.Row="1"
                                  Grid.Column="1"
                                  MinWidth="150"
                                  SelectedIndex="{Binding ReportHistory.SelectedRecentReportLimitIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="10 个" />
                            <ComboBoxItem Content="20 个" />
                            <ComboBoxItem Content="50 个" />
                        </ComboBox>
                        <Button x:Name="ClearRecentReportsButton"
                                Grid.Row="1"
                                Grid.Column="2"
                                Command="{Binding ClearRecentReportsCommand}"
                                ToolTipService.ToolTip="清空报告历史">
                            <FontIcon Glyph="&#xE894;"
                                      FontSize="14" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSectionStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="日志"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <Grid x:Name="RuntimeLogGrid"
                          ColumnSpacing="16"
                          RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="0" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="LogSummaryColumn" Width="*" />
                            <ColumnDefinition x:Name="LogControlColumn" Width="Auto" />
                            <ColumnDefinition x:Name="LogButtonColumn" Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel x:Name="RuntimeLogSummary"
                                    Spacing="2"
                                    VerticalAlignment="Center">
                            <TextBlock Text="运行日志"
                                       Style="{StaticResource SettingsRowTitleTextStyle}" />
                            <TextBlock Text="{Binding RuntimeLogs.RetentionText}"
                                       Style="{StaticResource SettingsRowSecondaryTextStyle}" />
                        </StackPanel>
                        <ComboBox x:Name="LogRetentionComboBox"
                                  Grid.Column="1"
                                  MinWidth="150"
                                  SelectedIndex="{Binding RuntimeLogs.SelectedRetentionIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="200 条" />
                            <ComboBoxItem Content="500 条" />
                            <ComboBoxItem Content="1000 条" />
                            <ComboBoxItem Content="2000 条" />
                        </ComboBox>
                        <Button x:Name="ClearRuntimeLogsButton"
                                Grid.Column="2"
                                Command="{Binding ClearRuntimeLogsCommand}"
                                ToolTipService.ToolTip="清空运行日志">
                            <FontIcon Glyph="&#xE894;"
                                      FontSize="14" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSectionStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Text="窗口与通知"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <Grid x:Name="WindowOptionsGrid"
                          ColumnSpacing="20"
                          RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="0" />
                            <RowDefinition Height="0" />
                            <RowDefinition Height="0" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="WindowOptionsColumn0" Width="*" />
                            <ColumnDefinition x:Name="WindowOptionsColumn1" Width="*" />
                        </Grid.ColumnDefinitions>

                        <ToggleSwitch x:Name="CloseToTrayToggle"
                                      Header="关闭后最小化到托盘"
                                      IsOn="{Binding CloseToTrayOnClose, Mode=TwoWay}" />
                        <ToggleSwitch x:Name="DesktopNotificationsToggle"
                                      Grid.Column="1"
                                      Header="桌面通知"
                                      IsOn="{Binding EnableDesktopNotifications, Mode=TwoWay}" />
                        <ToggleSwitch x:Name="StartMinimizedToggle"
                                      Grid.Row="1"
                                      Header="启动时隐藏到托盘"
                                      IsOn="{Binding StartMinimizedToTray, Mode=TwoWay}" />
                        <ToggleSwitch x:Name="AutoStartToggle"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      Header="登录后自动启动"
                                      IsOn="{Binding AutoStartOnSignIn, Mode=TwoWay}" />
                        <TextBlock x:Name="StartupIntegrationText"
                                   Grid.Row="2"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding StartupIntegrationStatusText}"
                                   Style="{StaticResource SettingsRowSecondaryTextStyle}" />
                        <StackPanel x:Name="GlobalHotkeyPanel"
                                    Grid.Row="3"
                                    Spacing="8">
                            <ToggleSwitch Header="全局热键"
                                          IsOn="{Binding EnableGlobalHotkeys, Mode=TwoWay}" />
                            <TextBlock Text="{Binding GlobalHotkeyStatusText}"
                                       Style="{StaticResource SettingsRowSecondaryTextStyle}" />
                        </StackPanel>
                        <StackPanel x:Name="QuickActionsPanel"
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Spacing="8">
                            <ComboBox Header="快速操作快捷键"
                                      SelectedIndex="{Binding SelectedQuickActionsShortcutIndex, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Ctrl+K" />
                                <ComboBoxItem Content="Ctrl+Shift+P" />
                                <ComboBoxItem Content="关闭" />
                            </ComboBox>
                            <TextBlock Text="{Binding QuickActionsShortcutText}"
                                       Style="{StaticResource SettingsRowSecondaryTextStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SettingsSectionStyle}">
                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="桌面健康"
                                       Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="{Binding DesktopHealth.SummaryText}"
                                       Style="{StaticResource SettingsRowSecondaryTextStyle}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding RefreshDesktopHealthCommand}"
                                VerticalAlignment="Center"
                                ToolTipService.ToolTip="刷新桌面健康状态">
                            <FontIcon Glyph="&#xE72C;"
                                      FontSize="14" />
                        </Button>
                    </Grid>

                    <Grid x:Name="DesktopHealthGrid"
                          ColumnSpacing="16"
                          RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="0" />
                            <RowDefinition Height="0" />
                            <RowDefinition Height="0" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="DesktopHealthColumn0" Width="*" />
                            <ColumnDefinition x:Name="DesktopHealthColumn1" Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="NotificationHealthText"
                                   Text="{Binding DesktopHealth.NotificationText}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="StartupHealthText"
                                   Grid.Column="1"
                                   Text="{Binding DesktopHealth.StartupText}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="SettingsHealthText"
                                   Grid.Row="1"
                                   Text="{Binding DesktopHealth.SettingsText}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="PackageHealthText"
                                   Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding DesktopHealth.PackageText}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="PythonBridgeHealthText"
                                   Grid.Row="2"
                                   Text="{Binding DesktopHealth.PythonBridgeText}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="InstallHealthText"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding DesktopHealth.InstallText}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="HotkeyHealthText"
                                   Grid.Row="3"
                                   Grid.ColumnSpan="2"
                                   Text="{Binding DesktopHealth.HotkeyText}"
                                   TextWrapping="WrapWholeWords" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
