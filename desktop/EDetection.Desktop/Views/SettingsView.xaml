                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="更新源" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <TextBox Grid.Column="1" Text="{Binding UpdateFeedUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="更新源" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="手动操作" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Grid x:Name="UpdateActionGrid" Grid.Column="1" ColumnSpacing="8" RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Command="{Binding CheckForUpdatesCommand}" HorizontalAlignment="Stretch" AutomationProperties.Name="检查更新">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE895;" FontSize="14" />
                                                <TextBlock Text="检查更新" />
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Command="{Binding OpenUpdateFeedCommand}" HorizontalAlignment="Stretch" AutomationProperties.Name="打开更新页面">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                                                <TextBlock Text="打开页面" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel x:Name="AdvancedSection" Spacing="8">
                        <TextBlock Text="高级" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SettingsGroupStyle}">
                            <StackPanel>
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="应用状态" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Button Grid.Column="1" Command="{Binding RefreshDesktopHealthCommand}" HorizontalAlignment="Stretch" AutomationProperties.Name="刷新应用状态">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                                            <TextBlock Text="刷新状态" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="检测组件运行程序" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <Grid Grid.Column="1" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding PythonExecutable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEditRunConfiguration}" PlaceholderText="默认检测组件" AutomationProperties.Name="检测组件运行程序" />
                                        <Button Grid.Column="1" Click="BrowsePythonExecutable_Click" IsEnabled="{Binding CanEditRunConfiguration}" AutomationProperties.Name="选择检测组件运行程序" ToolTipService.ToolTip="选择检测组件运行程序">
                                            <FontIcon Glyph="&#xE756;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="设置存储" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{Binding DesktopHealth.SettingsText}" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                </Grid>
                                <Border Height="1" Margin="18,0" Background="{ThemeResource SettingsRowDividerBrush}" />
                                <Grid MinHeight="64" Padding="18,10" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" MaxWidth="320" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="检测组件状态" Style="{StaticResource SettingsRowTitleTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{Binding DesktopHealth.PythonBridgeText}" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        <Border x:Name="SettingsFooter" Grid.Row="2" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="24,12">
            <Grid x:Name="SettingsFooterLayout" ColumnSpacing="16" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <InfoBar x:Name="SettingsFeedbackBar" IsOpen="{Binding IsSettingsFeedbackOpen, Mode=TwoWay}" Message="{Binding SettingsFeedbackText}" Severity="{Binding SettingsFeedbackSeverity}" IsIconVisible="True" IsClosable="True" MaxWidth="520" HorizontalAlignment="Left" VerticalAlignment="Center" />
                <StackPanel x:Name="SettingsFooterActions" Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10">
                    <Button Command="{Binding ResetSettingsToDefaultsCommand}" MinWidth="120" AutomationProperties.Name="重置设置">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                            <TextBlock Text="重置设置" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SaveSettingsFromPageCommand}" Style="{StaticResource AccentButtonStyle}" MinWidth="128" AutomationProperties.Name="保存设置">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74E;" FontSize="14" />
                            <TextBlock Text="保存设置" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
