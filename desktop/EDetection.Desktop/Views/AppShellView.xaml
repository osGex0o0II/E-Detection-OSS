<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="EDetection.Desktop.Views.AppShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:EDetection.Desktop.Views"
    mc:Ignorable="d">

    <Grid x:Name="Root"
          Background="Transparent"
          SizeChanged="Root_SizeChanged">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                <FontIcon Glyph="&#xE9D9;"
                          Foreground="{StaticResource BrandAccentBrush}"
                          FontSize="16" />
                <TextBlock Text="E-Detection"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock Text="原生检测工作台"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Margin="0,0,148,0"
                        Height="44"
                        VerticalAlignment="Top">
                <Button x:Name="SettingsTitleBarButton"
                        Style="{StaticResource TitleBarIconButtonStyle}"
                        Click="SettingsButton_Click"
                        AutomationProperties.Name="设置"
                        ToolTipService.ToolTip="设置 (Ctrl+S)">
                    <FontIcon Glyph="&#xE713;" FontSize="14" />
                </Button>
                <Button Style="{StaticResource TitleBarIconButtonStyle}"
                        Click="AboutButton_Click"
                        AutomationProperties.Name="关于"
                        ToolTipService.ToolTip="关于 (Ctrl+I)">
                    <FontIcon Glyph="&#xE946;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <Border x:Name="StatusBand"
                Grid.Row="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,1"
                Padding="24,8">
            <Grid x:Name="StatusLayout"
                  ColumnSpacing="18"
                  RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="StatusCommandColumn" Width="Auto" />
                    <ColumnDefinition x:Name="StatusTextColumn" Width="*" />
                    <ColumnDefinition x:Name="StatusProgressColumn" Width="220" />
                </Grid.ColumnDefinitions>

                <CommandBar x:Name="PrimaryCommandBar"
                            Background="Transparent"
                            DefaultLabelPosition="Right"
                            IsDynamicOverflowEnabled="True">
                    <AppBarButton x:Name="StartButton"
                                  Label="开始检测"
                                  AutomationProperties.Name="开始检测"
                                  ToolTipService.ToolTip="开始检测 (F5)"
                                  Command="{Binding StartCommand}">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE768;" FontSize="14" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton x:Name="CancelButton"
                                  Label="{Binding CancelButtonText}"
                                  AutomationProperties.Name="{Binding CancelButtonText}"
                                  ToolTipService.ToolTip="取消检测 (Esc)"
                                  Command="{Binding CancelCommand}">
                        <AppBarButton.Icon>
                            <FontIcon Glyph="&#xE711;" FontSize="14" />
                        </AppBarButton.Icon>
                    </AppBarButton>
                    <CommandBar.SecondaryCommands>
                        <AppBarButton x:Name="DiagnosticsButton"
                                      Label="检查状态"
                                      AutomationProperties.Name="检查状态"
                                      ToolTipService.ToolTip="检查状态 (F6)"
                                      Command="{Binding RefreshDiagnosticsCommand}">
                            <AppBarButton.Icon>
                                <FontIcon Glyph="&#xE895;" FontSize="14" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </CommandBar.SecondaryCommands>
                </CommandBar>

                <StackPanel x:Name="StatusTextPanel"
                            Grid.Column="1"
                            Spacing="2"
                            VerticalAlignment="Center">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding WorkbenchStatusText}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding WorkbenchStatusBadgeText}"
                                   MaxWidth="320"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                    <TextBlock Text="{Binding WorkbenchContextText}"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel x:Name="ProgressPanel"
                            Grid.Column="2"
                            Spacing="5"
                            VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding WorkbenchProcessedSummary}"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding WorkbenchProgressText}"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                    <ProgressBar Minimum="0"
                                 Maximum="100"
                                 Value="{Binding WorkbenchProgressPercent}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="WorkbenchLayout"
              Grid.Row="2"
              Padding="24"
              ColumnSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="0" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SetupColumn" Width="380" />
                <ColumnDefinition x:Name="WorkbenchColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <views:RunSetupView x:Name="RunSetup"
                                Grid.Column="0" />
            <ScrollViewer x:Name="WorkbenchScroll"
                          Grid.Column="1"
                          HorizontalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          VerticalScrollMode="Enabled">
                <views:DetectionWorkbenchView x:Name="DetectionWorkbench"
                                              Margin="0,0,20,0" />
            </ScrollViewer>
        </Grid>

        <views:SettingsView x:Name="ShellSettings"
                            Grid.Row="1"
                            Grid.RowSpan="2"
                            Visibility="Collapsed" />
    </Grid>
</UserControl>
